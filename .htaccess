# ==================================================
# CORE SECURITY
# ==================================================

# Disable directory listing
Options -Indexes

# Custom 404 page
ErrorDocument 404 /404.html

RewriteEngine On
RewriteBase /
# ==================================================
# FORCE HTTPS + REMOVE WWW (CANONICAL DOMAIN)
# ==================================================

RewriteCond %{HTTP_HOST} !^localhost$ [NC]
RewriteCond %{HTTPS} off [OR]
RewriteCond %{HTTP_HOST} ^www\. [NC]
RewriteCond %{HTTP_HOST} ^(?:www\.)?(.+)$ [NC]
RewriteRule ^ https://%1%{REQUEST_URI} [L,R=301]


# ==================================================
# CLEAN URLS (REMOVE .php)
# ==================================================

# Skip 
RewriteRule ^(robots\.txt|sitemap\.xml) - [L]
RewriteCond %{REQUEST_URI} ^/js/ajax/ [NC]
RewriteRule ^ - [L]

# Redirect .php to clean URL (IMPORTANT for SEO)
RewriteCond %{THE_REQUEST} \s/([^.]+)\.php [NC]
RewriteRule ^(.+)\.php$ $1 [R=301,L]

# Internally map clean URL to .php file
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.+)$ $1.php [L]


# ==================================================
# PROTECT SENSITIVE FILES
# ==================================================

# Protect .htaccess
<Files ".htaccess">
    Require all denied
</Files>

# Block hidden files (.git, .env, etc.)
<FilesMatch "^\.">
    Require all denied
</FilesMatch>

# Block config / backup files
<FilesMatch "\.(env|log|ini|bak|old|sql|yml|yaml)$">
    Require all denied
</FilesMatch>


# ==================================================
# BROWSER CACHING (CSS / JS / IMAGES / FONTS)
# ==================================================
<IfModule mod_expires.c>
    ExpiresActive On

    ExpiresByType text/css "access plus 1 month"

    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType text/javascript "access plus 1 month"

    ExpiresByType image/jpg "access plus 1 month"
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType image/gif "access plus 1 month"
    ExpiresByType image/webp "access plus 1 month"
    ExpiresByType image/svg+xml "access plus 1 month"
    ExpiresByType image/x-icon "access plus 1 month"

    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType application/vnd.ms-fontobject "access plus 1 year"
</IfModule>

<IfModule mod_headers.c>
    <FilesMatch "\.(css|js|jpg|jpeg|png|gif|webp|svg|ico|woff|woff2|eot)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
</IfModule>


# ==================================================
# SECURITY HEADERS
# ==================================================
<IfModule mod_headers.c>

    # Enforce HTTPS (HSTS)
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"

    # Content Security Policy (CSP)
    Header set Content-Security-Policy "default-src 'self'; script-src 'self' https://*.google.com https://*.googletagmanager.com https://*.google-analytics.com https://*.googleadservices.com https://*.doubleclick.net https://*.gstatic.com https://maps.googleapis.com https://maps.gstatic.com https://www.tripadvisor.com https://*.tawk.to https://cdnjs.cloudflare.com https://script.google.com https://script.googleusercontent.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://static.tacdn.com https://*.tawk.to; font-src 'self' https://fonts.gstatic.com https://*.gstatic.com https://*.tawk.to; img-src 'self' data: https://*.google.com https://*.googleadservices.com https://*.google-analytics.com https://*.googletagmanager.com https://*.doubleclick.net https://*.gstatic.com https://maps.googleapis.com https://maps.gstatic.com https://www.tripadvisor.com https://*.tawk.to https://static.tacdn.com; connect-src 'self' https://*.google.com https://*.googleadservices.com https://*.google-analytics.com https://*.googletagmanager.com https://*.doubleclick.net https://*.gstatic.com https://maps.googleapis.com https://www.google.fi https://www.tripadvisor.com https://*.tawk.to wss://*.tawk.to https://cdnjs.cloudflare.com https://script.google.com https://script.googleusercontent.com; frame-src https://*.google.com https://maps.google.com https://*.doubleclick.net https://www.tripadvisor.com https://*.tawk.to; frame-ancestors 'none'; base-uri 'self'; form-action 'self' https://script.google.com https://script.googleusercontent.com;"

    # Extra hardening
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "DENY"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    Header set Permissions-Policy "geolocation=(), microphone=(), camera=()"

</IfModule>